<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>potocki :: terms of service</title>
<style>
  :root {
    --brand: #cc4a2c;
    --brand-dark: #b33e22;
    --text-main: #333333;
    --text-muted: #666666;
    --bg-main: #f8f9fa;
    --bg-card: #ffffff;
    --border: #e0e0e0;
    --sans: 'Inter', -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
  }
  * { margin: 0; padding: 0; box-sizing: border-box; }
  body { font-family: var(--sans); color: var(--text-main); background: var(--bg-main); line-height: 1.7; min-height: 100vh; }
  .navbar { display: flex; justify-content: space-between; align-items: center; padding: 20px 40px; background: var(--brand); color: #fff; }
  .navbar .logo { font-size: 1.5em; font-weight: 700; text-decoration: none; color: #fff; }
  .container { max-width: 800px; margin: 60px auto; padding: 0 20px; }
  .card { background: var(--bg-card); border-radius: 8px; box-shadow: 0 10px 30px rgba(0,0,0,0.05); border: 1px solid var(--border); padding: 40px; }
  h1 { font-size: 2em; font-weight: 800; margin-bottom: 30px; color: var(--brand-dark); }
  h2 { font-size: 1.2em; font-weight: 700; margin: 30px 0 10px; color: var(--text-main); }
  p, li { color: var(--text-muted); margin-bottom: 12px; }
  ul { padding-left: 20px; margin-bottom: 20px; }
  a { color: var(--brand); text-decoration: none; font-weight: 600; }
  a:hover { text-decoration: underline; }
  footer { text-align: center; padding: 30px; color: var(--text-muted); font-size: 0.9em; border-top: 1px solid var(--border); margin-top: 60px; background: #fff; }
  @media (max-width: 600px) { .navbar { padding: 15px 20px; } .card { padding: 25px; } }
</style>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">
</head>
<body>

<div class="navbar">
  <a href="/" class="logo">potocki</a>
</div>

<div class="container">
